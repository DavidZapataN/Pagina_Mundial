# Base de datos
# Para desarrollo local: sqlite:///world_cup.db
# Para producción Docker: sqlite:////app/data/world_cup.db
# Para producción con PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///world_cup.db

# Clave secreta para firmar las sesiones (CAMBIAR en producción)
SECRET_KEY=una-clave-secreta-muy-larga-y-aleatoria

# Modo debug (false en producción)
DEBUG=false

# Nombre de usuario del administrador
ADMIN_USERNAME=admin

# Clave API de football-data.org (para actualizar resultados automáticamente)
# Registro gratuito en: https://www.football-data.org/client/register
FOOTBALL_API_KEY=tu_clave_aqui
